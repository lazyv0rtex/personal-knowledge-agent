# You can configure the provider + API key in the app (Settings → Model & API keys).
# The values saved there are stored at ./.data/settings.json and take precedence
# over the env vars below. Env vars are only used as a fallback for the *currently
# selected* provider.

# GitHub push token (needs repo scope)
GITHUB_TOKEN=ghp_...

# OpenRouter — https://openrouter.ai/keys  (default provider)
OPENROUTER_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Notes + vector store paths
NOTES_DIR=./notes
VECTOR_STORE_DIR=./vector_store
